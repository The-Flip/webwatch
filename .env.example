# Webwatch environment variables
# Copy to .env and fill in your values: cp .env.example .env
# Never commit .env — it holds secrets.

# --- HTTP fetching ---
# Identify ourselves politely to the sites we check. Include a contact URL.
WEBWATCH_USER_AGENT=webwatch/0.1 (+https://www.theflip.museum/; monitoring our own listings)

# Per-request timeout (seconds) and retries for transient failures (429 / 5xx).
WEBWATCH_HTTP_TIMEOUT=30
WEBWATCH_HTTP_MAX_RETRIES=3

# Minimum delay (seconds) between requests to the same domain (politeness).
WEBWATCH_HTTP_DOMAIN_DELAY=1.0

# --- Facts & state ---
# The museum's local timezone (used to decide when an event has expired).
WEBWATCH_TIMEZONE=America/Chicago

# Canonical expected facts and dynamic rules.
WEBWATCH_FACTS_PATH=facts.yaml

# Where run-to-run check state is persisted (for alert-on-transition / anti-flap).
WEBWATCH_STATE_PATH=state.json

# How many consecutive failing runs before a problem alerts (absorbs transient blips).
WEBWATCH_ALERT_AFTER_FAILURES=2

# How many consecutive healthy runs clear a fired alert (recovery hysteresis).
WEBWATCH_RECOVER_AFTER_SUCCESSES=1

# --- Email notification (transactional SMTP) ---
# Leave WEBWATCH_EMAIL_DRY_RUN=true to print emails instead of sending them.
WEBWATCH_EMAIL_DRY_RUN=true
# Port 587 (STARTTLS) is the usual submission port; 25 is blocked on most hosts.
# For Gmail app passwords use SMTP_HOST=smtp.gmail.com. Leave USERNAME/PASSWORD
# blank to relay without auth (e.g. an IP-allowlisted Workspace SMTP relay).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
WEBWATCH_SMTP_TIMEOUT=30
WEBWATCH_EMAIL_FROM=
WEBWATCH_EMAIL_TO=
